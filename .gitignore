# =============================================
# FastFix .gitignore
# =============================================

# Environment & Secrets
.env
.env.local
.env.*.local

# IDE
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS
Thumbs.db
Desktop.ini
.DS_Store

# ---- Backend (.NET) ----
backend/**/bin/
backend/**/obj/
backend/**/*.user
backend/**/*.suo

# ---- Frontend (React/Vite) ----
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ---- AI Service (Python) ----
ai-service/__pycache__/
ai-service/**/__pycache__/
ai-service/*.pyc
ai-service/.venv/
ai-service/venv/
ai-service/*.egg-info/

# Docker
docker-compose.override.yml

# Logs
*.log
logs/
